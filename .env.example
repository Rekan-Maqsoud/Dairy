# Public values used by the Expo app at runtime
EXPO_PUBLIC_APPWRITE_ENDPOINT="https://fra.cloud.appwrite.io/v1"
EXPO_PUBLIC_APPWRITE_PROJECT_ID="your_project_id"
EXPO_PUBLIC_APPWRITE_DATABASE_ID="dairy_db"
EXPO_PUBLIC_APPWRITE_COLLECTION_ID="diary_entries"

# Server-side only (used by npm run appwrite:setup)
APPWRITE_API_KEY="your_appwrite_api_key"
